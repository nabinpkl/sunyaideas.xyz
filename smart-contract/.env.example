# Copy to .env and fill in. Never commit .env.
# Source it before forge commands:  set -a; source .env; set +a

# Sepolia RPC endpoint. Public options: https://ethereum-sepolia-rpc.publicnode.com
# Or a keyed endpoint from Alchemy / Infura for higher rate limits.
SEPOLIA_RPC_URL=


# Etherscan v2 API key (single key works for all chains).
# Only needed if you pass --verify to forge script.
ETHERSCAN_API_KEY=

BASE_RPC_URL=
